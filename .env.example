# Copy to .env and fill in locally. On ECS, prefer .streamlit/secrets.toml (see secrets.toml.example) or systemd env.
DEEPSEEK_API_KEY=
# Optional — same vars as cloud systemd (default DeepSeek if unset)
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# OPENAI_API_BASE=
# OPENAI_API_KEY=
# Optional — LLM timeout tuning (seconds)
# NOESIS_LLM_TIMEOUT_SECONDS=60
# NOESIS_STEP_TIMEOUT_SECONDS=60
# --- Supabase（可选）：云端持久化审计日志 → 表 agentos_public_logs，详见 docs/supabase_setup.md ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
